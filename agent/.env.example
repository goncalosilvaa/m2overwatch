# Base de dados de LOG do jogo (onde esta a bot_suspicion_log)
M2OW_DB_HOST=127.0.0.1
M2OW_DB_PORT=3306
M2OW_DB_USER=metin2
M2OW_DB_PASS=PASSWORD_DA_DB
M2OW_DB_NAME=log
M2OW_TABLE=bot_suspicion_log

# Painel (endpoint de ingestao) + API key do servidor (cria em /servers)
M2OW_API_URL=https://o-teu-painel.vercel.app/api/ingest
M2OW_API_KEY=cola_aqui_a_api_key

# 60 = daemon (a cada 60s). 0 = corre uma vez e sai (para cron).
M2OW_POLL_SECONDS=60
