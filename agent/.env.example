# ===== Painel =====
M2OW_API_URL=https://m2overwatch.vercel.app/api/ingest
M2OW_API_KEY=cola_aqui_a_api_key_do_servidor
# (M2OW_API_BASE e derivado do API_URL; so define se usares um caminho diferente)

# ===== DB de LOG do jogo (origem das detecoes) =====
M2OW_DB_HOST=127.0.0.1
M2OW_DB_PORT=3306
M2OW_DB_USER=metin2
M2OW_DB_PASS=PASSWORD_DA_DB_LOG
M2OW_DB_NAME=log
M2OW_TABLE=bot_suspicion_log

# 60 = daemon (cada 60s). 0 = corre uma vez e sai (para cron).
M2OW_POLL_SECONDS=60

# ===== BANS: DB de CONTAS do jogo (utilizador do anti-cheat) =====
M2OW_BANS_ENABLE=1
M2OW_ACC_DB_HOST=127.0.0.1
M2OW_ACC_DB_PORT=3306
M2OW_ACC_DB_USER=anticheat
M2OW_ACC_DB_PASS=PASSWORD_DO_UTILIZADOR_ANTICHEAT
M2OW_ACC_DB_NAME=account
# SQL do ban (por defeito: bloquear a conta pelo login). %s = login.
M2OW_BAN_SQL=UPDATE account.account SET status='BLOCK' WHERE login=%s
