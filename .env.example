# --- Base de dados (Postgres / Neon) ---
# Usa a connection string "pooled" da Neon (acaba em ...-pooler...).
DATABASE_URL="postgresql://user:pass@host-pooler.neon.tech/neondb?sslmode=require"

# --- Segredo para assinar a sessao do painel ---
# Gera uma string aleatoria longa:  openssl rand -hex 32
AUTH_SECRET="muda-para-uma-string-aleatoria-bem-longa"

# --- Admin de arranque (bootstrap) ---
# No 1.o login, se a DB ainda nao tiver utilizadores, e criado este admin (na DB, com hash).
# Depois disso, faz a gestao de contas em /users.
ADMIN_EMAIL="admin@m2overwatch.gg"
ADMIN_PASSWORD="muda-esta-password"
